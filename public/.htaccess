<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Redirect bare domain to www (skip ACME challenges so SSL issuance keeps working)
  RewriteCond %{HTTP_HOST} ^digital-twilight\.com$ [NC]
  RewriteCond %{REQUEST_URI} !^/\.well-known/
  RewriteRule ^(.*)$ %{REQUEST_SCHEME}://www.digital-twilight.com/$1 [R=301,L]

  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
